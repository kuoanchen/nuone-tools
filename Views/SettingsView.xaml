<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="nuone_tools.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="18"
                    Padding="20"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource PanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel Spacing="18">
                    <TextBlock Text="設定"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="28"
                               FontWeight="SemiBold" />

                    <TextBox PlaceholderText="在設定中尋找"
                             IsReadOnly="True"
                             Background="{StaticResource InputAltBrush}"
                             BorderBrush="{StaticResource PanelStrokeBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" />

                    <Button Click="ShowGeneralSettings_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="GeneralSettingsNavBorder"
                                Padding="14,12"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="GeneralSettingsNavText"
                                       Text="一般"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Button>

                    <Button Click="ShowAppearanceSettings_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="AppearanceSettingsNavBorder"
                                Padding="14,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="AppearanceSettingsNavText"
                                       Text="外觀"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" />
                        </Border>
                    </Button>

                    <Button Click="ShowAccountSettings_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="AccountSettingsNavBorder"
                                Padding="14,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="AccountSettingsNavText"
                                       Text="帳號"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" />
                        </Border>
                    </Button>

                    <Button Click="ShowShortcutSettings_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="ShortcutSettingsNavBorder"
                                Padding="14,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="ShortcutSettingsNavText"
                                       Text="快捷鍵"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" />
                        </Border>
                    </Button>

                    <Button Click="ShowToolbarSettings_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="ToolbarSettingsNavBorder"
                                Padding="14,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <TextBlock x:Name="ToolbarSettingsNavText"
                                       Text="工具列"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16" />
                        </Border>
                    </Button>

                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="0,18,18,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18">
                    <TextBlock x:Name="SettingsPageTitle"
                               Text="一般"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="34"
                               FontWeight="SemiBold" />

                    <TextBlock x:Name="SettingsPageDescription"
                               Text="設定檔案顯示、內建終端機預設與常用鍵盤快捷鍵。變更後會立即儲存到本機 config。"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="16"
                               TextWrapping="Wrap" />

                    <StackPanel x:Name="GeneralSettingsContent"
                                Spacing="18"
                                Visibility="Visible">
                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="檔案顯示"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="顯示隱藏與系統檔案"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="包含 Hidden、System、ReparsePoint 項目。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <ToggleSwitch x:Name="ShowHiddenSystemItemsToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  OffContent="關"
                                                  OnContent="開"
                                                  Toggled="ShowHiddenSystemItemsToggle_Toggled" />
                                </Grid>

                                <TextBlock Text="選取總大小"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Margin="0,8,0,0" />

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="計算檔案總大小"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="選取多個檔案時，顯示它們的總大小。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <ToggleSwitch x:Name="ShowSelectedFileSizeToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  OffContent="關"
                                                  OnContent="開"
                                                  Toggled="ShowSelectedFileSizeToggle_Toggled" />
                                </Grid>

                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Spacing="6">
                                        <TextBlock Text="計算資料夾總大小"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="選取資料夾時，遞迴計算資料夾內所有檔案總大小。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <ToggleSwitch x:Name="ShowSelectedFolderSizeToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  OffContent="關"
                                                  OnContent="開"
                                                  Toggled="ShowSelectedFolderSizeToggle_Toggled" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="內建終端機預設"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <StackPanel Spacing="10">
                                    <TextBlock Text="預設 shell 類型"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="新開內建終端機 tab 和新建的 terminal 工具列按鈕，會先使用這個 shell。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                    <ComboBox x:Name="DefaultTerminalShellComboBox"
                                              SelectionChanged="DefaultTerminalShellComboBox_SelectionChanged"
                                              Background="{StaticResource InputAltBrush}"
                                              BorderBrush="{StaticResource PanelStrokeBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}">
                                        <ComboBoxItem Content="PowerShell" Tag="PowerShell" />
                                        <ComboBoxItem Content="Git Bash" Tag="GitBash" />
                                        <ComboBoxItem Content="cmd" Tag="CommandPrompt" />
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="預設工作目錄"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="控制新開內建終端機預設落在哪個資料夾。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                    <ComboBox x:Name="DefaultTerminalWorkingDirectoryModeComboBox"
                                              SelectionChanged="DefaultTerminalWorkingDirectoryModeComboBox_SelectionChanged"
                                              Background="{StaticResource InputAltBrush}"
                                              BorderBrush="{StaticResource PanelStrokeBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}">
                                        <ComboBoxItem Content="目前作用中的 pane" Tag="ActivePane" />
                                        <ComboBoxItem Content="左側 pane" Tag="LeftPane" />
                                        <ComboBoxItem Content="右側 pane" Tag="RightPane" />
                                        <ComboBoxItem Content="自訂路徑" Tag="CustomPath" />
                                    </ComboBox>
                                    <TextBox x:Name="DefaultTerminalCustomWorkingDirectoryTextBox"
                                             TextChanged="DefaultTerminalCustomWorkingDirectoryTextBox_TextChanged"
                                             PlaceholderText="例如：C:\trabajo 或 \\dsm\video"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}"
                                             Visibility="Collapsed" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="診斷 Log"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="crash、ssh、icon、storage 等診斷 log 會寫到這個目錄。變更後立即生效。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />

                                <StackPanel Spacing="10">
                                    <TextBlock Text="Log 目錄"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="LogDirectoryPathTextBox"
                                             TextChanged="LogDirectoryPathTextBox_TextChanged"
                                             PlaceholderText="例如：C:\Soft\nuone-tools\logs"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Click="UseDefaultLogDirectoryButton_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="使用預設" />
                                        <Button Click="OpenLogDirectoryButton_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="開啟目錄" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="線上更新"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="檢查 Nuone Tools 是否有新版可用。發現新版後會先詢問是否下載，再確認是否安裝並重新啟動。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />

                                <StackPanel Spacing="10">
                                    <TextBlock Text="目前版本"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="CurrentAppVersionTextBlock"
                                               Text="載入中"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="更新來源"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="UpdateManifestUrlTextBlock"
                                               Text="https://cdn.nuone.cl/nuone-tools/manifest.json"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button x:Name="CheckForUpdatesButton"
                                            Click="CheckForUpdatesButton_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="檢查更新" />
                                </StackPanel>

                                <StackPanel x:Name="AppUpdateActionButtonsPanel"
                                            Orientation="Horizontal"
                                            Spacing="10"
                                            Visibility="Collapsed">
                                    <Button x:Name="OpenUpdateDownloadButton"
                                            Click="OpenUpdateDownloadButton_Click"
                                            Style="{StaticResource AccentButtonStyle}"
                                            Content="下載並安裝" />
                                    <Button x:Name="CopyUpdateDownloadUrlButton"
                                            Click="CopyUpdateDownloadUrlButton_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="複製下載連結" />
                                </StackPanel>

                                <TextBlock x:Name="AppUpdateStatusTextBlock"
                                           Text="尚未檢查更新"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />

                                <TextBlock x:Name="LatestAppVersionTextBlock"
                                           Text="最新版本：尚未檢查"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />

                                <TextBlock x:Name="LastAppUpdateCheckTextBlock"
                                           Text="上次檢查：尚未檢查"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />

                                <TextBlock x:Name="AppUpdateReleaseNotesTextBlock"
                                           Text=""
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Border>

                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="本機資料備份"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="settings-local.json 不再自動同步。這裡可以手動把目前本機資料備份到後端。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <Button Click="BackupLocalSettingsButton_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="備份本機資料" />
                                </StackPanel>

                                <TextBlock x:Name="LastLocalBackupTextBlock"
                                           Text="尚未備份"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="14"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Padding="24"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="18">
                            <StackPanel Spacing="18">
                                <TextBlock Text="FileBunker 上傳"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="24"
                                           FontWeight="SemiBold" />

                                <TextBlock Text="提供工具列的 FileBunker 上傳按鈕使用。設定會儲存在 Nuone Tools 的 settings-sync.json，不再讀外部 .env。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />

                                <StackPanel Spacing="10">
                                    <TextBlock Text="輸入端點"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerInputEndpointTextBox"
                                             TextChanged="FileBunkerInputEndpointTextBox_TextChanged"
                                             PlaceholderText="https://filein.filebunker.com"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="輸出端點"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerOutputEndpointTextBox"
                                             TextChanged="FileBunkerOutputEndpointTextBox_TextChanged"
                                             PlaceholderText="https://out.filebunker.com"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="Client ID"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerClientIdTextBox"
                                             TextChanged="FileBunkerClientIdTextBox_TextChanged"
                                             PlaceholderText="例如：14015"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock Text="Key Length"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerKeyLengthTextBox"
                                             TextChanged="FileBunkerKeyLengthTextBox_TextChanged"
                                             PlaceholderText="64"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="到期天數"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerDaysToExpirationTextBox"
                                             TextChanged="FileBunkerDaysToExpirationTextBox_TextChanged"
                                             PlaceholderText="3650"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Spacing="10">
                                    <TextBlock Text="清除天數"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerDaysToPurgeTextBox"
                                             TextChanged="FileBunkerDaysToPurgeTextBox_TextChanged"
                                             PlaceholderText="20"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="API Key"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="FileBunkerApiKeyTextBox"
                                             TextChanged="FileBunkerApiKeyTextBox_TextChanged"
                                             PlaceholderText="輸入 FileBunker API key"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <Border x:Name="AccountSettingsContent"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                        <StackPanel Spacing="18">
                            <TextBlock Text="帳號"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="連接 https://api.nuone.cl 的 identity login。密碼只用於當次登入，會寫進 settings-local.json。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15"
                                       TextWrapping="Wrap" />

                            <StackPanel x:Name="AccountLoginFieldsPanel"
                                        Spacing="18">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="API"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="AccountApiUrlTextBox"
                                             TextChanged="AccountApiUrlTextBox_TextChanged"
                                             PlaceholderText="https://api.nuone.cl"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="Email"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBox x:Name="AccountEmailTextBox"
                                             TextChanged="AccountEmailTextBox_TextChanged"
                                             PlaceholderText="you@example.com"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Spacing="10">
                                    <TextBlock Text="Password"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <PasswordBox x:Name="AccountPasswordBox"
                                                 PlaceholderText="輸入密碼後登入"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button x:Name="LoginAccountButton"
                                        Click="LoginAccountButton_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Content="登入" />
                            </StackPanel>

                            <Border x:Name="AccountConnectionStatusCard"
                                    Padding="16"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="連線狀態"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock x:Name="AccountConnectionStatusTextBlock"
                                               Text="尚未登入"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="使用者"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" />
                                        <TextBlock x:Name="AccountUserTextBlock"
                                                   Grid.Column="1"
                                                   Text="尚未登入"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="服務帳號"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" />
                                        <TextBlock x:Name="AccountServiceAccountsTextBlock"
                                                   Grid.Column="1"
                                                   Text="尚未取得"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="上次登入"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" />
                                        <TextBlock x:Name="AccountLastLoginTextBlock"
                                                   Grid.Column="1"
                                                   Text="尚未登入"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Token"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" />
                                        <TextBlock x:Name="AccountTokenTextBlock"
                                                   Grid.Column="1"
                                                   Text="尚未登入"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="14"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="Login payload"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="14" />
                                        <TextBox x:Name="AccountPayloadJsonTextBox"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="120"
                                                 MaxHeight="260"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AppearanceSettingsContent"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                        <StackPanel Spacing="18">
                            <TextBlock Text="外觀"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="選擇 Nuone Tools 使用深色、淺色，或跟隨 Windows 系統。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15"
                                       TextWrapping="Wrap" />
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="280" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="應用程式主題"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="會立即套用到主畫面與應用程式內建對話框。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <ComboBox x:Name="ThemeModeComboBox"
                                          Grid.Column="1"
                                          SelectionChanged="ThemeModeComboBox_SelectionChanged"
                                          Background="{StaticResource InputAltBrush}"
                                          BorderBrush="{StaticResource PanelStrokeBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <ComboBoxItem Content="依系統" Tag="System" />
                                    <ComboBoxItem Content="暗黑模式" Tag="Dark" />
                                    <ComboBoxItem Content="明亮模式" Tag="Light" />
                                </ComboBox>
                            </Grid>

                            <Border Padding="14"
                                    Background="{StaticResource CardBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock Text="原生 Windows 複製 / 搬移進度視窗會跟隨 Windows 系統主題。若要連 copy progress 一起變更，請使用「依系統」或調整 Windows 本身的主題。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15"
                                       TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="ShortcutSettingsContent"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                        <StackPanel Spacing="18">
                            <TextBlock Text="快捷鍵"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="複製到另一個 Pane"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，複製選取項目到另一側。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CopyShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditCopyShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="移動到另一個 Pane"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，將選取項目搬移到另一側。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MoveShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditMoveShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="上一層"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，回到上一層目錄。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NavigateUpShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditNavigateUpShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="新增資料夾"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，使用 Ctrl + Shift + [這顆鍵] 新增資料夾。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CreateFolderShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditCreateFolderShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="刪除"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，刪除選取項目。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DeleteShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditDeleteShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="CaptureHintTextBlock"
                                       Text="按「修改」後，再按下實體鍵，會立即套用。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="ToolbarSettingsContent"
                            Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Visibility="Collapsed">
                        <StackPanel Spacing="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Spacing="6">
                                    <TextBlock Text="工具列"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="設定上方工具列按鈕。按下後會在目前作用中的 pane 路徑執行 command。拖曳可重新排序。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Click="AddToolbarCommand_Click"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Content="新增工具" />
                            </Grid>

                            <ListView x:Name="ToolbarCommandsListView"
                                      ItemsSource="{Binding ToolbarCommands}"
                                      CanDragItems="True"
                                      CanReorderItems="True"
                                      AllowDrop="True"
                                      SelectionMode="None"
                                      IsItemClickEnabled="False"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ItemContainerStyle="{StaticResource GroupCardListViewItemStyle}"
                                      DragItemsCompleted="ToolbarCommandsListView_DragItemsCompleted">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:ToolbarCommandItem">
                                        <Border Margin="0,0,0,12"
                                                Padding="0"
                                                Background="{StaticResource CardBrush}"
                                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <Grid ColumnSpacing="16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="52"
                                                        Height="52"
                                                        Background="{StaticResource InputBrush}"
                                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12">
                                                    <Grid Tag="{x:Bind}"
                                                          Loaded="ToolbarIconPresenter_Loaded"
                                                          DataContextChanged="ToolbarIconPresenter_DataContextChanged">
                                                        <Image Width="24"
                                                               Height="24"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Stretch="Uniform"
                                                               Visibility="Collapsed" />
                                                        <FontIcon Glyph="{x:Bind DisplayGlyph, Mode=OneWay}"
                                                                  FontSize="24"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="1" Spacing="4">
                                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="17"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{x:Bind Command, Mode=OneWay}"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="14"
                                                               TextWrapping="WrapWholeWords" />
                                                    <TextBlock Tag="{x:Bind}"
                                                               Loaded="ToolbarIconSummary_Loaded"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               FontSize="13" />
                                                </StackPanel>

                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                    <Button Tag="{x:Bind}"
                                                            Click="EditToolbarCommand_Click"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Content="編輯" />
                                                    <Button Tag="{x:Bind}"
                                                            Click="DeleteToolbarCommand_Click"
                                                            Style="{StaticResource GhostButtonStyle}"
                                                            Content="刪除" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
