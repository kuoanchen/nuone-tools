<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="nuone_tools.Views.AutomationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools">
    <UserControl.Resources>
        <Style x:Key="AutomationListViewItemStyle"
               TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="IsTabStop" Value="False" />
        </Style>
        <Style x:Key="AutomationFormLabelStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="AutomationFormHintStyle"
               TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0"
                Padding="0"
                Visibility="Collapsed"
                Background="{StaticResource PanelAltBrush}"
                BorderBrush="{StaticResource PanelStrokeBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="5">
                        <TextBlock Text="建立自動化"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="27"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="建立後可從右側表格管理、執行、啟停與刪除。"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Padding="18"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Spacing="14">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="42"
                                        Height="42"
                                        Background="{StaticResource InputAltBrush}"
                                        CornerRadius="12">
                                    <FontIcon Glyph="&#xE710;"
                                              FontSize="18"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="3">
                                    <TextBlock Text="新增自動化工作"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="20"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="按下後選擇備份或自動解壓，再填寫細節。"
                                               Style="{StaticResource AutomationFormHintStyle}" />
                                </StackPanel>
                            </Grid>

                            <Button Click="AddAutomationDialog_Click"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Content="新增自動化" />
                        </StackPanel>
                    </Border>

                    <Border Padding="18"
                            Visibility="Collapsed"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Spacing="11">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="38"
                                        Height="38"
                                        Background="{StaticResource InputAltBrush}"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE8B7;"
                                              FontSize="17"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="新增備份工作"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="檔案同步或 MongoDB 排程備份"
                                               Style="{StaticResource AutomationFormHintStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="工作類型" Style="{StaticResource AutomationFormLabelStyle}" />
                            <ComboBox x:Name="AutomationJobTypeComboBox"
                                      SelectedIndex="0"
                                      HorizontalAlignment="Stretch"
                                      Background="{StaticResource InputAltBrush}"
                                      BorderBrush="{StaticResource PanelStrokeBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      SelectionChanged="AutomationJobTypeComboBox_SelectionChanged">
                                <ComboBoxItem Content="檔案備份" Tag="FileBackup" />
                                <ComboBoxItem Content="MongoDB 備份" Tag="MongoBackup" />
                            </ComboBox>

                            <TextBlock Text="工作名稱" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutomationNameTextBox"
                                     PlaceholderText="例如：文件每日備份"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Text="目的地資料夾" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutomationDestinationPathTextBox"
                                     PlaceholderText="例如：D:\backup"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <StackPanel x:Name="AutomationFileSettingsPanel" Spacing="8">
                                <TextBlock Text="來源路徑" Style="{StaticResource AutomationFormLabelStyle}" />
                                <TextBox x:Name="AutomationSourcePathTextBox"
                                         PlaceholderText="例如：C:\Users\...\Documents"
                                         Background="{StaticResource InputAltBrush}"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}" />

                                <TextBlock Text="備份模式" Style="{StaticResource AutomationFormLabelStyle}" />
                                <ComboBox x:Name="AutomationModeComboBox"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          Background="{StaticResource InputAltBrush}"
                                          BorderBrush="{StaticResource PanelStrokeBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}">
                                    <ComboBoxItem Content="備份複製" Tag="Copy" />
                                    <ComboBoxItem Content="同步鏡像" Tag="Mirror" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel x:Name="AutomationMongoSettingsPanel"
                                        Spacing="8"
                                        Visibility="Collapsed">
                                <TextBlock Text="mongodump 路徑" Style="{StaticResource AutomationFormLabelStyle}" />
                                <TextBox x:Name="AutomationMongoToolPathTextBox"
                                         Text="C:\Program Files\MongoDB\Tools\100\bin\mongodump.exe"
                                         PlaceholderText="mongodump.exe"
                                         Background="{StaticResource InputAltBrush}"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}" />

                                <TextBlock Text="Mongo URI" Style="{StaticResource AutomationFormLabelStyle}" />
                                <TextBox x:Name="AutomationMongoConnectionStringTextBox"
                                         PlaceholderText="mongodb://..."
                                         Background="{StaticResource InputAltBrush}"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         TextWrapping="Wrap" />

                                <TextBlock Text="資料庫名稱" Style="{StaticResource AutomationFormLabelStyle}" />
                                <TextBox x:Name="AutomationMongoDatabaseNameTextBox"
                                         PlaceholderText="db1, db2；留空表示全部"
                                         Background="{StaticResource InputAltBrush}"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True" />

                                <TextBlock Text="輸出設定" Style="{StaticResource AutomationFormLabelStyle}" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="118" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             x:Name="AutomationMongoRetentionCountTextBox"
                                             Header="保留份數"
                                             Text="7"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="14"
                                                VerticalAlignment="Bottom"
                                                Margin="0,0,0,8">
                                        <CheckBox x:Name="AutomationMongoUseArchiveCheckBox"
                                                  IsChecked="True"
                                                  Content="Archive" />
                                        <CheckBox x:Name="AutomationMongoUseGzipCheckBox"
                                                  IsChecked="True"
                                                  Content="GZip" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>

                            <TextBlock Text="執行排程" Style="{StaticResource AutomationFormLabelStyle}" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.25*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="AutomationScheduleTypeComboBox"
                                          SelectedIndex="0"
                                          HorizontalAlignment="Stretch"
                                          Background="{StaticResource InputAltBrush}"
                                          BorderBrush="{StaticResource PanelStrokeBrush}"
                                          Foreground="{StaticResource TextPrimaryBrush}"
                                          SelectionChanged="AutomationScheduleTypeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="每隔幾分鐘" Tag="Interval" />
                                    <ComboBoxItem Content="每天固定時間" Tag="Daily" />
                                    <ComboBoxItem Content="每週固定時間" Tag="Weekly" />
                                </ComboBox>

                                <StackPanel Grid.Column="1"
                                            x:Name="AutomationIntervalSchedulePanel">
                                    <TextBox x:Name="AutomationIntervalTextBox"
                                             PlaceholderText="分鐘"
                                             Text="60"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            x:Name="AutomationTimeSchedulePanel"
                                            Visibility="Collapsed">
                                    <TextBox x:Name="AutomationScheduleTimeTextBox"
                                             PlaceholderText="HH:mm"
                                             Text="03:00"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="AutomationWeeklyDaysPanel"
                                        Spacing="8"
                                        Visibility="Collapsed">
                                <TextBlock Text="執行星期" Style="{StaticResource AutomationFormLabelStyle}" />
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                        <CheckBox x:Name="AutomationWeeklyMondayCheckBox" IsChecked="True" Content="週一" />
                                        <CheckBox x:Name="AutomationWeeklyTuesdayCheckBox" IsChecked="True" Content="週二" />
                                        <CheckBox x:Name="AutomationWeeklyWednesdayCheckBox" IsChecked="True" Content="週三" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                        <CheckBox x:Name="AutomationWeeklyThursdayCheckBox" IsChecked="True" Content="週四" />
                                        <CheckBox x:Name="AutomationWeeklyFridayCheckBox" IsChecked="True" Content="週五" />
                                        <CheckBox x:Name="AutomationWeeklySaturdayCheckBox" Content="週六" />
                                        <CheckBox x:Name="AutomationWeeklySundayCheckBox" Content="週日" />
                                </StackPanel>
                            </StackPanel>

                            <CheckBox x:Name="AutomationRunMissedOnStartupCheckBox"
                                      Content="啟動 app 時補跑錯過的排程" />

                            <Border Padding="11"
                                    Background="{StaticResource InputAltBrush}"
                                    CornerRadius="10">
                                <TextBlock x:Name="AutomationHintTextBlock"
                                           Text="同步鏡像會讓目的地維持和來源一致，會刪除目的地多出來的檔案與資料夾。"
                                           Foreground="{StaticResource WarningBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap" />
                            </Border>

                            <Button Click="AddAutomationJob_Click"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Content="建立備份工作" />
                        </StackPanel>
                    </Border>

                    <Border Padding="18"
                            Visibility="Collapsed"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Spacing="10">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="38"
                                        Height="38"
                                        Background="{StaticResource InputAltBrush}"
                                        CornerRadius="10">
                                    <FontIcon Glyph="&#xE7B8;"
                                              FontSize="17"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="新增自動解壓"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="19"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="監看資料夾並自動處理壓縮檔"
                                               Style="{StaticResource AutomationFormHintStyle}" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="工作名稱" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutoExtractNameTextBox"
                                     PlaceholderText="例如：收據自動解壓"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Text="監看目錄" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutoExtractWatchPathTextBox"
                                     PlaceholderText="例如：C:\Users\...\Downloads"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Text="解壓工具" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutoExtractExtractorPathTextBox"
                                     PlaceholderText="留空會自動尋找 7z.exe / WinRAR.exe"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Text="副檔名篩選" Style="{StaticResource AutomationFormLabelStyle}" />
                            <TextBox x:Name="AutoExtractExtensionFilterTextBox"
                                     Text=".zip, .rar, .7z"
                                     PlaceholderText="副檔名篩選，例如：.zip, .7z；留空表示全部"
                                     Background="{StaticResource InputAltBrush}"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <TextBlock Text="可用逗號或空白分隔；留空代表全部支援格式。密碼清單可在建立後透過右側編輯按鈕管理。"
                                       Style="{StaticResource AutomationFormHintStyle}" />

                            <Button Click="AddAutoExtractProfile_Click"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Content="建立自動解壓" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <ScrollViewer Grid.Column="1"
                      Margin="18"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="18">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="自動化工作"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="34"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />

                    <Button Grid.Column="1"
                            Click="AddAutomationDialog_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Padding="18,8"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="新增自動化" />
                        </StackPanel>
                    </Button>
                </Grid>

                <TextBlock Text="備份工作會依排程在背景執行；自動解壓會監看指定目錄中的壓縮檔。所有工作都可以隨時手動執行。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="16"
                           TextWrapping="Wrap" />

                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <Grid Padding="14,12"
                              Background="{StaticResource PanelAltBrush}"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="名稱" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="類型" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="排程" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="狀態" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="上次執行" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="結果" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="操作" FontWeight="SemiBold" />
                        </Grid>

                        <ListView ItemsSource="{Binding BackupAutomations}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  ItemContainerStyle="{StaticResource AutomationListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:BackupAutomationProfile">
                                    <Border Padding="14,11"
                                            BorderBrush="{StaticResource PanelStrokeBrush}"
                                            BorderThickness="0,1,0,0">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.25*" />
                                                <ColumnDefinition Width="0.8*" />
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="190" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{x:Bind JobTypeText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind ScheduleDescription, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <ProgressRing Width="14"
                                                              Height="14"
                                                              IsActive="True"
                                                              Visibility="{x:Bind RunningIndicatorVisibility, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind StateText, Mode=OneWay}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="4"
                                                       Text="{x:Bind LastRunText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="5"
                                                       Text="{x:Bind LastResultText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="6"
                                                        Orientation="Horizontal"
                                                        Spacing="6">
                                                <Button Tag="{x:Bind}"
                                                        Click="EditAutomationJob_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                        ToolTipService.ToolTip="編輯"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="RunAutomationNow_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanRunNow, Mode=OneWay}"
                                                        ToolTipService.ToolTip="立即執行"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="StartAutomationJob_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanStart, Mode=OneWay}"
                                                        Visibility="{x:Bind StartButtonVisibility, Mode=OneWay}"
                                                        ToolTipService.ToolTip="啟用"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE8FB;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="StopAutomationJob_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanStop, Mode=OneWay}"
                                                        Visibility="{x:Bind StopButtonVisibility, Mode=OneWay}"
                                                        ToolTipService.ToolTip="停止"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="DeleteAutomationJob_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanDelete, Mode=OneWay}"
                                                        ToolTipService.ToolTip="刪除"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <ListView Visibility="Collapsed"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ItemContainerStyle="{StaticResource AutomationListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:BackupAutomationProfile">
                            <Border Margin="0,0,0,14"
                                    Padding="18"
                                    Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18">
                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBox Text="{x:Bind Name, Mode=TwoWay}"
                                                     Tag="{x:Bind}"
                                                     TextChanged="AutomationNameTextBox_TextChanged"
                                                     IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                     Background="{StaticResource InputAltBrush}"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="14"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <ToggleSwitch Grid.Column="1"
                                                      Margin="16,0,0,0"
                                                      IsOn="{x:Bind IsEnabled, Mode=TwoWay}"
                                                      IsEnabled="{x:Bind CanToggleEnabled, Mode=OneWay}"
                                                      Tag="{x:Bind}"
                                                      Toggled="AutomationEnabledToggle_Toggled"
                                                      OffContent="停用"
                                                      OnContent="啟用" />
                                    </Grid>

                                    <ComboBox Tag="{x:Bind}"
                                              Loaded="AutomationJobTypeItemComboBox_Loaded"
                                              SelectionChanged="AutomationJobTypeItemComboBox_SelectionChanged"
                                              IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                              Background="{StaticResource InputAltBrush}"
                                              BorderBrush="{StaticResource PanelStrokeBrush}"
                                              Foreground="{StaticResource TextPrimaryBrush}">
                                        <ComboBoxItem Content="檔案備份" Tag="FileBackup" />
                                        <ComboBoxItem Content="MongoDB 備份" Tag="MongoBackup" />
                                    </ComboBox>

                                    <TextBox Text="{x:Bind SourcePath, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             TextChanged="AutomationSourcePathTextBox_TextChanged"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             Visibility="{x:Bind SourcePathVisibility, Mode=OneWay}"
                                             PlaceholderText="來源路徑"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <TextBox Text="{x:Bind DestinationPath, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             TextChanged="AutomationDestinationPathTextBox_TextChanged"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             PlaceholderText="目的地資料夾"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0"
                                                  Tag="{x:Bind}"
                                                  Loaded="AutomationModeComboBox_Loaded"
                                                  SelectionChanged="AutomationModeComboBox_SelectionChanged"
                                                  IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                  Visibility="{x:Bind FileModeRowVisibility, Mode=OneWay}"
                                                  Background="{StaticResource InputAltBrush}"
                                                  BorderBrush="{StaticResource PanelStrokeBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}">
                                            <ComboBoxItem Content="備份複製" Tag="Copy" />
                                            <ComboBoxItem Content="同步鏡像" Tag="Mirror" />
                                        </ComboBox>

                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind ModeDescription, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <StackPanel Spacing="10"
                                                Visibility="{x:Bind MongoSettingsVisibility, Mode=OneWay}">
                                        <TextBox Text="{x:Bind MongoToolPath, Mode=TwoWay}"
                                                 Tag="{x:Bind}"
                                                 TextChanged="AutomationMongoToolPathTextBox_TextChanged"
                                                 IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                 PlaceholderText="mongodump 路徑"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />

                                        <TextBox Text="{x:Bind MongoConnectionString, Mode=TwoWay}"
                                                 Tag="{x:Bind}"
                                                 TextChanged="AutomationMongoConnectionStringTextBox_TextChanged"
                                                 IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                 PlaceholderText="Mongo URI"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 TextWrapping="Wrap" />

                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="220" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Text="{x:Bind MongoDatabaseName, Mode=TwoWay}"
                                                     Tag="{x:Bind}"
                                                     TextChanged="AutomationMongoDatabaseNameTextBox_TextChanged"
                                                     IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                     PlaceholderText="資料庫名稱，可多個，留空表示全部"
                                                     Background="{StaticResource InputAltBrush}"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"
                                                     TextWrapping="Wrap"
                                                     AcceptsReturn="True" />

                                            <TextBox Grid.Column="1"
                                                     Text="{x:Bind MongoRetentionCountText, Mode=TwoWay}"
                                                     Tag="{x:Bind}"
                                                     TextChanged="AutomationMongoRetentionCountTextBox_TextChanged"
                                                     IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                     PlaceholderText="保留份數"
                                                     Background="{StaticResource InputAltBrush}"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" Spacing="16">
                                            <CheckBox IsChecked="{x:Bind MongoUseArchive, Mode=TwoWay}"
                                                      Tag="{x:Bind}"
                                                      Click="AutomationMongoUseArchiveCheckBox_Click"
                                                      IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                      Content="Archive" />
                                            <CheckBox IsChecked="{x:Bind MongoUseGzip, Mode=TwoWay}"
                                                      Tag="{x:Bind}"
                                                      Click="AutomationMongoUseGzipCheckBox_Click"
                                                      IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                      Content="GZip" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <ComboBox Grid.Column="0"
                                                  Tag="{x:Bind}"
                                                  Loaded="AutomationScheduleTypeComboBox_Loaded"
                                                  SelectionChanged="AutomationScheduleTypeComboBox_SelectionChanged"
                                                  IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                  Background="{StaticResource InputAltBrush}"
                                                  BorderBrush="{StaticResource PanelStrokeBrush}"
                                                  Foreground="{StaticResource TextPrimaryBrush}">
                                            <ComboBoxItem Content="每隔幾分鐘" Tag="Interval" />
                                            <ComboBoxItem Content="每天固定時間" Tag="Daily" />
                                            <ComboBoxItem Content="每週固定時間" Tag="Weekly" />
                                        </ComboBox>

                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind ScheduleDescription, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBox Text="{x:Bind IntervalMinutesText, Mode=TwoWay}"
                                             Tag="{x:Bind}"
                                             TextChanged="AutomationIntervalTextBox_TextChanged"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             Visibility="{x:Bind IntervalScheduleVisibility, Mode=OneWay}"
                                             PlaceholderText="間隔分鐘"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <StackPanel Spacing="10"
                                                Visibility="{x:Bind ScheduledTimeVisibility, Mode=OneWay}">
                                        <TextBox Text="{x:Bind ScheduleTimeText, Mode=TwoWay}"
                                                 Tag="{x:Bind}"
                                                 TextChanged="AutomationScheduleTimeTextBox_TextChanged"
                                                 IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                 PlaceholderText="時間，例如：03:00"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />

                                        <StackPanel Spacing="8"
                                                    Visibility="{x:Bind WeeklyDaysVisibility, Mode=OneWay}">
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <CheckBox IsChecked="{x:Bind WeeklyMondaySelected, Mode=TwoWay}"
                                                          Tag="Monday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週一" />
                                                <CheckBox IsChecked="{x:Bind WeeklyTuesdaySelected, Mode=TwoWay}"
                                                          Tag="Tuesday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週二" />
                                                <CheckBox IsChecked="{x:Bind WeeklyWednesdaySelected, Mode=TwoWay}"
                                                          Tag="Wednesday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週三" />
                                                <CheckBox IsChecked="{x:Bind WeeklyThursdaySelected, Mode=TwoWay}"
                                                          Tag="Thursday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週四" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="12">
                                                <CheckBox IsChecked="{x:Bind WeeklyFridaySelected, Mode=TwoWay}"
                                                          Tag="Friday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週五" />
                                                <CheckBox IsChecked="{x:Bind WeeklySaturdaySelected, Mode=TwoWay}"
                                                          Tag="Saturday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週六" />
                                                <CheckBox IsChecked="{x:Bind WeeklySundaySelected, Mode=TwoWay}"
                                                          Tag="Sunday"
                                                          Click="AutomationWeeklyDayCheckBox_Click"
                                                          IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                          Content="週日" />
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox IsChecked="{x:Bind RunMissedOnStartup, Mode=TwoWay}"
                                              Tag="{x:Bind}"
                                              Click="AutomationRunMissedOnStartupCheckBox_Click"
                                              IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                              Content="啟動 app 時補跑錯過的排程" />

                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0"
                                                Tag="{x:Bind}"
                                                Click="StartAutomationJob_Click"
                                                IsEnabled="{x:Bind CanStart, Mode=OneWay}"
                                                Visibility="{x:Bind StartButtonVisibility, Mode=OneWay}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="啟動" />

                                        <Button Grid.Column="1"
                                                Tag="{x:Bind}"
                                                Click="RunAutomationNow_Click"
                                                IsEnabled="{x:Bind CanRunNow, Mode=OneWay}"
                                                Visibility="{x:Bind RunButtonVisibility, Mode=OneWay}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="立即執行" />

                                        <Button Grid.Column="2"
                                                Tag="{x:Bind}"
                                                Click="StopAutomationJob_Click"
                                                IsEnabled="{x:Bind CanStop, Mode=OneWay}"
                                                Visibility="{x:Bind StopButtonVisibility, Mode=OneWay}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="停止" />

                                        <Button Grid.Column="3"
                                                Tag="{x:Bind}"
                                                Click="DeleteAutomationJob_Click"
                                                IsEnabled="{x:Bind CanDelete, Mode=OneWay}"
                                                Visibility="{x:Bind DeleteButtonVisibility, Mode=OneWay}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Content="刪除" />
                                    </Grid>

                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="上次執行"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13" />
                                            <TextBlock Text="{x:Bind LastRunText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="下次執行"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13" />
                                            <TextBlock Text="{x:Bind NextRunText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <Grid>
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="結果"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="13" />
                                            <TextBlock Text="{x:Bind LastResultText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="{x:Bind WarningText, Mode=OneWay}"
                                               Foreground="{StaticResource WarningBrush}"
                                               FontSize="13"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock Margin="0,12,0,0"
                           Text="自動解壓"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="28"
                           FontWeight="SemiBold" />

                <TextBlock Text="監看指定目錄中出現的壓縮檔，依密碼清單自動嘗試解壓。預設支援 .zip、.rar、.7z，會解到同目錄下同名資料夾。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="15"
                           TextWrapping="Wrap" />

                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource PanelStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="14">
                    <StackPanel>
                        <Grid Padding="14,12"
                              Background="{StaticResource PanelAltBrush}"
                              ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="190" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="名稱" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="類型" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="2" Text="監看條件" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="3" Text="狀態" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="4" Text="上次執行" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="5" Text="結果" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="6" Text="操作" FontWeight="SemiBold" />
                        </Grid>

                        <ListView ItemsSource="{Binding AutoExtractProfiles}"
                                  SelectionMode="None"
                                  IsItemClickEnabled="False"
                                  ItemContainerStyle="{StaticResource AutomationListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:AutoExtractProfile">
                                    <Border Padding="14,11"
                                            BorderBrush="{StaticResource PanelStrokeBrush}"
                                            BorderThickness="0,1,0,0">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1.4*" />
                                                <ColumnDefinition Width="1.1*" />
                                                <ColumnDefinition Width="1.25*" />
                                                <ColumnDefinition Width="0.8*" />
                                                <ColumnDefinition Width="1.15*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="190" />
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="自動解壓"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{x:Bind TriggerText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="3"
                                                        Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <ProgressRing Width="14"
                                                              Height="14"
                                                              IsActive="True"
                                                              Visibility="{x:Bind RunningIndicatorVisibility, Mode=OneWay}" />
                                                <TextBlock Text="{x:Bind StateText, Mode=OneWay}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="4"
                                                       Text="{x:Bind LastRunText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="5"
                                                       Text="{x:Bind LastResultText, Mode=OneWay}"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <StackPanel Grid.Column="6"
                                                        Orientation="Horizontal"
                                                        Spacing="6">
                                                <Button Tag="{x:Bind}"
                                                        Click="EditAutoExtractProfile_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                        ToolTipService.ToolTip="編輯"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="RunAutoExtractNow_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanRunNow, Mode=OneWay}"
                                                        ToolTipService.ToolTip="立即執行"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="StartAutoExtractProfile_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanStart, Mode=OneWay}"
                                                        Visibility="{x:Bind StartButtonVisibility, Mode=OneWay}"
                                                        ToolTipService.ToolTip="啟用"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE8FB;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="StopAutoExtractProfile_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanStop, Mode=OneWay}"
                                                        Visibility="{x:Bind StopButtonVisibility, Mode=OneWay}"
                                                        ToolTipService.ToolTip="停止"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                                                </Button>
                                                <Button Tag="{x:Bind}"
                                                        Click="DeleteAutoExtractProfile_Click"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        IsEnabled="{x:Bind CanDelete, Mode=OneWay}"
                                                        ToolTipService.ToolTip="刪除"
                                                        Width="34"
                                                        Height="34"
                                                        Padding="0">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <ListView Visibility="Collapsed"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ItemContainerStyle="{StaticResource AutomationListViewItemStyle}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:AutoExtractProfile">
                            <Border Margin="0,0,0,14"
                                    Padding="18"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Opacity="{x:Bind CardOpacity, Mode=OneWay}">
                                <StackPanel Spacing="12">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBox Text="{x:Bind Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextChanged="AutoExtractNameTextBox_TextChanged"
                                                 Tag="{x:Bind}"
                                                 IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                 Background="{StaticResource InputAltBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}" />

                                        <ToggleSwitch Grid.Column="1"
                                                      Tag="{x:Bind}"
                                                      IsOn="{x:Bind IsEnabled, Mode=OneWay}"
                                                      IsEnabled="{x:Bind CanToggleEnabled, Mode=OneWay}"
                                                      Toggled="AutoExtractEnabledToggle_Toggled"
                                                      VerticalAlignment="Center"
                                                      OffContent="關"
                                                      OnContent="開" />
                                    </Grid>

                                    <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />

                                    <TextBox Text="{x:Bind WatchPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="AutoExtractWatchPathTextBox_TextChanged"
                                             Tag="{x:Bind}"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             PlaceholderText="監看目錄"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <TextBox Text="{x:Bind ExtractorPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="AutoExtractExtractorPathTextBox_TextChanged"
                                             Tag="{x:Bind}"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             PlaceholderText="解壓工具路徑，可空白自動找 7z.exe / WinRAR.exe"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <TextBox Text="{x:Bind ExtensionFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             TextChanged="AutoExtractExtensionFilterTextBox_TextChanged"
                                             Tag="{x:Bind}"
                                             IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                             PlaceholderText="副檔名篩選，例如：.zip, .7z；留空表示全部"
                                             Background="{StaticResource InputAltBrush}"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="密碼清單"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />

                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Text="{x:Bind PendingPasswordText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="新增一組密碼"
                                                     IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                     Background="{StaticResource InputAltBrush}"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />

                                            <Button Grid.Column="1"
                                                    Tag="{x:Bind}"
                                                    Click="AddAutoExtractPassword_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    IsEnabled="{x:Bind CanEdit, Mode=OneWay}"
                                                    Content="新增" />
                                        </Grid>

                                        <ItemsControl ItemsSource="{x:Bind Passwords, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:AutoExtractPasswordItem">
                                                    <Grid ColumnSpacing="10"
                                                          Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <TextBox Text="{x:Bind Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 TextChanged="AutoExtractPasswordItemTextBox_TextChanged"
                                                                 Background="{StaticResource InputAltBrush}"
                                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                                 Foreground="{StaticResource TextPrimaryBrush}" />

                                                        <Button Grid.Column="1"
                                                                Tag="{x:Bind}"
                                                                Click="RemoveAutoExtractPassword_Click"
                                                                Style="{StaticResource GhostButtonStyle}"
                                                                Content="刪除" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Tag="{x:Bind}"
                                                Click="RunAutoExtractNow_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                IsEnabled="{x:Bind CanRunNow, Mode=OneWay}"
                                                Visibility="{x:Bind RunButtonVisibility, Mode=OneWay}"
                                                Content="立即執行" />
                                        <Button Tag="{x:Bind}"
                                                Click="StartAutoExtractProfile_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                IsEnabled="{x:Bind CanStart, Mode=OneWay}"
                                                Visibility="{x:Bind StartButtonVisibility, Mode=OneWay}"
                                                Content="啟動" />
                                        <Button Tag="{x:Bind}"
                                                Click="StopAutoExtractProfile_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                IsEnabled="{x:Bind CanStop, Mode=OneWay}"
                                                Visibility="{x:Bind StopButtonVisibility, Mode=OneWay}"
                                                Content="停止" />
                                        <Button Tag="{x:Bind}"
                                                Click="DeleteAutoExtractProfile_Click"
                                                Style="{StaticResource GhostButtonStyle}"
                                                IsEnabled="{x:Bind CanDelete, Mode=OneWay}"
                                                Visibility="{x:Bind DeleteButtonVisibility, Mode=OneWay}"
                                                Content="刪除" />
                                    </StackPanel>

                                    <Grid ColumnSpacing="24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="上次執行"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="14" />
                                            <TextBlock Text="{x:Bind LastRunText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock Text="結果"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="14" />
                                            <TextBlock Text="{x:Bind LastResultText, Mode=OneWay}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
