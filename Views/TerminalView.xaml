<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="nuone_tools.Views.TerminalView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools"
    RequestedTheme="Dark">
    <UserControl.Resources>
        <SolidColorBrush x:Key="TerminalPageBrush" Color="#111111" />
        <SolidColorBrush x:Key="TerminalSurfaceBrush" Color="#0C0C0C" />
        <SolidColorBrush x:Key="TerminalChromeBrush" Color="#202020" />
        <SolidColorBrush x:Key="TerminalChromeAltBrush" Color="#2B2B2B" />
        <SolidColorBrush x:Key="TerminalBorderBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="TerminalForegroundBrush" Color="#F2F2F2" />
        <SolidColorBrush x:Key="TerminalMutedBrush" Color="#A0A0A0" />
        <SolidColorBrush x:Key="TerminalAccentBrush" Color="#4CC2FF" />
        <SolidColorBrush x:Key="TerminalSuccessBrush" Color="#16C60C" />

        <Style x:Key="TerminalGhostButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TerminalForegroundBrush}" />
            <Setter Property="Background" Value="{StaticResource TerminalChromeAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TerminalBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="36" />
        </Style>

        <Style x:Key="TerminalPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource TerminalGhostButtonStyle}">
            <Setter Property="Background" Value="{StaticResource TerminalAccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource TerminalAccentBrush}" />
            <Setter Property="Foreground" Value="#0C0C0C" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource TerminalPageBrush}"
          Margin="18"
          RowSpacing="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="18,16"
                        Background="{StaticResource TerminalChromeBrush}"
                        BorderBrush="{StaticResource TerminalBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="6">
                        <TextBlock Text="Terminal"
                                   Foreground="{StaticResource TerminalForegroundBrush}"
                                   FontFamily="Cascadia Mono"
                                   FontSize="28"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="內建終端機會直接在 Nuone Tools 內執行 shell。點黑色 terminal 區域後可像 Windows Terminal 一樣直接輸入。"
                                   Foreground="{StaticResource TerminalMutedBrush}"
                                   FontSize="14"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Top">
                        <Button Click="SyncTerminalWorkingDirectory_Click"
                                Style="{StaticResource TerminalGhostButtonStyle}"
                                Content="同步目前路徑" />
                        <Button Click="ClearTerminalOutput_Click"
                                Style="{StaticResource TerminalGhostButtonStyle}"
                                Content="清空輸出" />
                        <Button Click="RestartTerminal_Click"
                                Style="{StaticResource TerminalPrimaryButtonStyle}"
                                Content="重新啟動" />
                    </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Background="{StaticResource TerminalChromeBrush}"
                        BorderBrush="{StaticResource TerminalBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <TabView x:Name="TerminalTabsView"
                             Background="{StaticResource TerminalChromeBrush}"
                             Foreground="{StaticResource TerminalForegroundBrush}"
                             BorderThickness="0"
                             Padding="2"
                             IsAddTabButtonVisible="True"
                             AddTabButtonClick="TerminalTabsView_AddTabButtonClick"
                             TabCloseRequested="TerminalTabsView_TabCloseRequested"
                             SelectionChanged="TerminalTabsView_SelectionChanged" />
                </Border>

                <StackPanel Grid.Row="2"
                            Visibility="Collapsed">
                    <ComboBox x:Name="TerminalShellComboBox"
                              SelectionChanged="TerminalShellComboBox_SelectionChanged">
                        <ComboBoxItem Content="PowerShell" Tag="PowerShell" />
                        <ComboBoxItem Content="Git Bash" Tag="GitBash" />
                        <ComboBoxItem Content="cmd" Tag="CommandPrompt" />
                    </ComboBox>
                    <TextBlock x:Name="TerminalShellTextBlock" />
                    <TextBlock x:Name="TerminalWorkingDirectoryTextBlock" />
                    <TextBlock x:Name="TerminalStatusTextBlock" />
                </StackPanel>

                <Border x:Name="TerminalHost"
                        Grid.Row="2"
                        Padding="0"
                        Background="{StaticResource TerminalSurfaceBrush}"
                        BorderBrush="{StaticResource TerminalBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        IsTabStop="True"
                        KeyDown="TerminalHost_KeyDown"
                        CharacterReceived="TerminalHost_CharacterReceived"
                        GotFocus="TerminalHost_GotFocus"
                        LostFocus="TerminalHost_LostFocus"
                        PointerPressed="TerminalHost_PointerPressed">
                    <Grid RowDefinitions="*,Auto">
                        <ScrollViewer x:Name="TerminalOutputScrollViewer"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto"
                                      MinHeight="420">
                            <RichTextBlock x:Name="TerminalOutputTextBlock"
                                           IsTextSelectionEnabled="True"
                                           Foreground="{StaticResource TerminalForegroundBrush}"
                                           FontFamily="Cascadia Mono"
                                           FontSize="14"
                                           Padding="18"
                                           TextWrapping="NoWrap"
                                           MinHeight="420" />
                        </ScrollViewer>

                        <Grid Grid.Row="1"
                              Padding="18"
                              ColumnSpacing="12"
                              Background="{StaticResource TerminalChromeBrush}"
                              Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="TerminalCommandTextBox"
                                     PlaceholderText="輸入命令後按 Enter"
                                     AcceptsReturn="False"
                                     KeyDown="TerminalCommandTextBox_KeyDown"
                                     Background="{StaticResource TerminalSurfaceBrush}"
                                     BorderBrush="{StaticResource TerminalBorderBrush}"
                                     Foreground="{StaticResource TerminalForegroundBrush}"
                                     FontFamily="Cascadia Mono"
                                     FontSize="14" />

                            <Button Grid.Column="1"
                                    Click="SendTerminalCommand_Click"
                                    Style="{StaticResource TerminalPrimaryButtonStyle}"
                                    Content="送出" />
                        </Grid>
                    </Grid>
                </Border>
    </Grid>
</UserControl>
