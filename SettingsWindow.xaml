<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="nuone_tools.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="設定">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout" Background="#141119">
        <Grid.Resources>
            <SolidColorBrush x:Key="PanelBrush" Color="#211C28" />
            <SolidColorBrush x:Key="PanelAltBrush" Color="#191520" />
            <SolidColorBrush x:Key="PanelStrokeBrush" Color="#3A3146" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F6F2FF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B9AECF" />
            <SolidColorBrush x:Key="AccentBrush" Color="#D092E4" />

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="#2A252F" />
                <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="14,8" />
                <Setter Property="MinHeight" Value="38" />
            </Style>

            <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="#1A1322" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="18"
                    Padding="20"
                    Background="{StaticResource PanelAltBrush}"
                    BorderBrush="{StaticResource PanelStrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="18">
                <StackPanel Spacing="18">
                    <TextBlock Text="設定"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="28"
                               FontWeight="SemiBold" />

                    <TextBox PlaceholderText="在設定中尋找"
                             IsReadOnly="True"
                             Background="#231E2B"
                             BorderBrush="{StaticResource PanelStrokeBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}" />

                    <TextBlock Text="一般"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" />

                    <TextBlock Text="外觀"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" />

                    <Border Padding="14,12"
                            Background="#2A252F"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <TextBlock Text="快捷鍵"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="16"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Margin="0,18,18,18"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="18">
                    <TextBlock Text="快捷鍵"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="34"
                               FontWeight="SemiBold" />

                    <TextBlock Text="設定常用鍵盤快捷鍵。變更後會立即套用，並儲存到本機 config。"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="16"
                               TextWrapping="Wrap" />

                    <Border Padding="24"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Spacing="18">
                            <TextBlock Text="快捷鍵"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />

                            <StackPanel Spacing="8">
                                <TextBlock Text="複製到另一個 Pane"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，複製選取項目到另一側。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CopyShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="#231E2B"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditCopyShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="移動到另一個 Pane"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，將選取項目搬移到另一側。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="MoveShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="#231E2B"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditMoveShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="上一層"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，回到上一層目錄。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NavigateUpShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="#231E2B"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditNavigateUpShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Spacing="8">
                                <TextBlock Text="刪除"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="18"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="目前作用中的 pane 按下後，刪除選取項目。"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="15"
                                           TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="DeleteShortcutTextBox"
                                             IsReadOnly="True"
                                             Background="#231E2B"
                                             BorderBrush="{StaticResource PanelStrokeBrush}"
                                             Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Button Grid.Column="1"
                                            Click="EditDeleteShortcut_Click"
                                            Style="{StaticResource GhostButtonStyle}"
                                            Content="修改" />
                                </Grid>
                            </StackPanel>

                            <TextBlock x:Name="CaptureHintTextBlock"
                                       Text="按「修改」後，再按下實體鍵。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="15"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1"
              Margin="18,0,18,18"
              ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="220" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1"
                    Click="SaveButton_Click"
                    Style="{StaticResource AccentButtonStyle}"
                    Content="儲存" />
            <Button Grid.Column="2"
                    Click="CancelButton_Click"
                    Style="{StaticResource GhostButtonStyle}"
                    Content="取消" />
        </Grid>
    </Grid>
</Window>
