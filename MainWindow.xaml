<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="nuone_tools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Nuone Tools">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout"
          Background="#141119"
          ActualThemeChanged="RootLayout_ActualThemeChanged">
        <Grid.Resources>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#141119" />
            <SolidColorBrush x:Key="PanelBrush" Color="#211C28" />
            <SolidColorBrush x:Key="PanelAltBrush" Color="#191520" />
            <SolidColorBrush x:Key="PanelStrokeBrush" Color="#3A3146" />
            <SolidColorBrush x:Key="AppRailBrush" Color="#0F2025" />
            <SolidColorBrush x:Key="AppRailBorderBrush" Color="#1F3138" />
            <SolidColorBrush x:Key="AppRailActiveBrush" Color="#2D2835" />
            <SolidColorBrush x:Key="AppRailActiveBorderBrush" Color="#4A3E58" />
            <SolidColorBrush x:Key="AppRailFooterBrush" Color="#171622" />
            <SolidColorBrush x:Key="AppRailFooterBorderBrush" Color="#2F2740" />
            <SolidColorBrush x:Key="CardBrush" Color="#2A252F" />
            <SolidColorBrush x:Key="InputBrush" Color="#1B1621" />
            <SolidColorBrush x:Key="InputAltBrush" Color="#231E2B" />
            <SolidColorBrush x:Key="AccentBrush" Color="#BF4CFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#8B35C4" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F6F2FF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B9AECF" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#74D89B" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFD76A" />
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="#00FFFFFF" />
                <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="MinHeight" Value="38" />
            </Style>

            <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            </Style>

            <Style x:Key="AppRailButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>

            <Style x:Key="GroupCardListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>

            <Style x:Key="PaneListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,2" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>

            <Style x:Key="ToolbarListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Center" />
                <Setter Property="VerticalContentAlignment" Value="Top" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <ContentPresenter
                                Margin="0"
                                Padding="0"
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,0,0"
                Background="{StaticResource AppRailBrush}"
                BorderBrush="{StaticResource AppRailBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="10,14,10,0" Spacing="10">
                    <Button x:Name="FileManagerAppButton"
                            Click="ShowFileManagerApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="FileManagerAppButtonBorder"
                                Padding="10,12"
                                Background="{StaticResource AppRailActiveBrush}"
                                BorderBrush="{StaticResource AppRailActiveBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="FileManagerAppIcon"
                                          Glyph="&#xE8B7;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="FileManagerAppText"
                                           Text="檔案"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <Button x:Name="AutomationAppButton"
                            Click="ShowAutomationApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="AutomationAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="AutomationAppIcon"
                                          Glyph="&#xE7B8;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="AutomationAppText"
                                           Text="自動化"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <Button x:Name="SettingsAppButton"
                            Click="ShowSettingsApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="SettingsAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="SettingsAppIcon"
                                          Glyph="&#xE713;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="SettingsAppText"
                                           Text="設定"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="10,0,10,14"
                            Spacing="10">
                    <Border Padding="10,12"
                            Background="{StaticResource AppRailFooterBrush}"
                            BorderBrush="{StaticResource AppRailFooterBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind AppVersionText, Mode=OneWay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Text="版本"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid x:Name="FileManagerView" Grid.Row="0" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="14,32,14,14"
                        Padding="16"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource PanelStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid RowDefinitions="Auto,*">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Nuone Tools"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="26"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Nuone工具"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Click="RefreshAll_Click"
                                    Style="{StaticResource GhostButtonStyle}">
                                <FontIcon Glyph="&#xE72C;" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,20,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="18">
                                <Border Padding="10"
                                        Background="{StaticResource CardBrush}"
                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="磁碟機" Style="{StaticResource SectionTitleStyle}" />
                                            <Button Grid.Column="1"
                                                    x:Name="DriveSectionMenuButton"
                                                    Style="{StaticResource GhostButtonStyle}">
                                                <FontIcon Glyph="&#xE712;" />
                                                <Button.Flyout>
                                                    <MenuFlyout Opening="DriveRestoreFlyout_Opening" />
                                                </Button.Flyout>
                                            </Button>
                                        </Grid>
                                        <ItemsControl ItemsSource="{x:Bind Drives, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:DriveShortcut">
                                                    <Button HorizontalAlignment="Stretch"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="DriveShortcut_Click"
                                                            RightTapped="DriveShortcut_RightTapped"
                                                            Tag="{x:Bind RootPath}">
                                                        <Border HorizontalAlignment="Stretch"
                                                                Margin="0,0,0,8"
                                                                Padding="12"
                                                                Background="{StaticResource CardBrush}"
                                                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel Spacing="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{x:Bind Name}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="14"
                                                                               FontWeight="SemiBold" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{x:Bind Summary}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                                </Grid>
                                                                <ProgressBar Value="{x:Bind UsagePercent}"
                                                                             Maximum="100"
                                                                             Height="6"
                                                                             Foreground="{StaticResource AccentBrush}"
                                                                             Background="#3A3146" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="自訂分組" Style="{StaticResource SectionTitleStyle}" />
                                        <Button Grid.Column="1"
                                                x:Name="AddGroupButton"
                                                Click="ShowAddGroupEditor_Click"
                                                Style="{StaticResource GhostButtonStyle}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" />
                                                <TextBlock Text="新增分組" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <StackPanel x:Name="AddGroupEditor"
                                                Visibility="Collapsed"
                                                Spacing="8">
                                        <TextBox x:Name="NewGroupNameTextBox"
                                                 PlaceholderText="輸入分組名稱"
                                                 Background="{StaticResource InputBrush}"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 KeyDown="NewGroupNameTextBox_KeyDown" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Click="ConfirmAddGroup_Click"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Content="建立" />
                                            <Button Grid.Column="1"
                                                    Click="CancelAddGroup_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="取消" />
                                        </Grid>
                                    </StackPanel>

                                    <ListView x:Name="CustomGroupsListView"
                                              ItemsSource="{x:Bind CustomGroups, Mode=OneWay}"
                                              CanDragItems="True"
                                              CanReorderItems="True"
                                              AllowDrop="True"
                                              SelectionMode="None"
                                              IsItemClickEnabled="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ItemContainerStyle="{StaticResource GroupCardListViewItemStyle}"
                                              DragItemsCompleted="CustomGroupsListView_DragItemsCompleted">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:PathGroup">
                                                        <Border Margin="0,0,0,10"
                                                                Padding="10"
                                                                Background="{StaticResource CardBrush}"
                                                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                    <StackPanel Spacing="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                                <Button Padding="0"
                                                                        Width="24"
                                                                        Height="24"
                                                                        MinHeight="24"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="6">
                                                                    <FontIcon Glyph="&#xE712;" />
                                                                    <Button.Flyout>
                                                                        <MenuFlyout>
                                                                            <MenuFlyoutItem Text="群組改名"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="RenameGroup_Click" />
                                                                            <MenuFlyoutItem Text="刪除分組"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="DeleteGroup_Click" />
                                                                            <MenuFlyoutSeparator />
                                                                            <MenuFlyoutItem Text="加入目前路徑"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="AddCurrentPathToGroup_Click" />
                                                                        </MenuFlyout>
                                                                    </Button.Flyout>
                                                                </Button>
                                                                <Button Padding="0"
                                                                        Width="24"
                                                                        Height="24"
                                                                        MinHeight="24"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="6"
                                                                        Click="AddCurrentPathToGroup_Click">
                                                                    <FontIcon Glyph="&#xE710;" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <ListView ItemsSource="{x:Bind Items}"
                                                                  CanDragItems="True"
                                                                  CanReorderItems="True"
                                                                  AllowDrop="True"
                                                                  SelectionMode="None"
                                                                  IsItemClickEnabled="False"
                                                                  Background="Transparent"
                                                                  BorderThickness="0"
                                                                  ItemContainerStyle="{StaticResource GroupCardListViewItemStyle}"
                                                                  DragItemsCompleted="GroupedPathsListView_DragItemsCompleted">
                                                            <ListView.ItemTemplate>
                                                                <DataTemplate x:DataType="local:GroupedPathItem">
                                                                    <Border HorizontalAlignment="Stretch"
                                                                            Margin="0,0,0,2"
                                                                            Padding="8,5"
                                                                            Background="Transparent"
                                                                            BorderBrush="Transparent"
                                                                            BorderThickness="0"
                                                                            CornerRadius="6"
                                                                            PointerEntered="GroupedPathItem_PointerEntered"
                                                                            PointerExited="GroupedPathItem_PointerExited"
                                                                            Tapped="GroupedPath_Tapped">
                                                                        <Border.ContextFlyout>
                                                                            <MenuFlyout>
                                                                                <MenuFlyoutItem Text="開啟"
                                                                                                Tag="{x:Bind}"
                                                                                                Click="GroupedPathOpen_Click" />
                                                                                <MenuFlyoutItem Text="更改別名"
                                                                                                Tag="{x:Bind}"
                                                                                                Click="RenameGroupedPathAlias_Click" />
                                                                                <MenuFlyoutItem Text="從分組移除"
                                                                                                Tag="{x:Bind}"
                                                                                                Click="RemoveGroupedPath_Click" />
                                                                            </MenuFlyout>
                                                                        </Border.ContextFlyout>
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto" />
                                                                                <ColumnDefinition Width="*" />
                                                                            </Grid.ColumnDefinitions>
                                                                            <FontIcon Glyph="&#xE8B7;"
                                                                                      Foreground="{StaticResource WarningBrush}"
                                                                                      Margin="0,0,8,0"
                                                                                      FontSize="13" />
                                                                            <StackPanel Grid.Column="1" Spacing="2">
                                                                                <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                                                           FontSize="13" />
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ListView.ItemTemplate>
                                                        </ListView>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="0,32,14,14" RowDefinitions="Auto,*">
                    <Grid Padding="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="TopCommandBarBorder"
                                Grid.Column="2"
                                Padding="4,3"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Border.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="新增工具"
                                                    Click="AddToolbarCommand_Click">
                                        <MenuFlyoutItem.Icon>
                                            <FontIcon Glyph="&#xE710;" />
                                        </MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Border.ContextFlyout>

                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <ListView x:Name="TopToolbarListView"
                                          ItemsSource="{x:Bind ToolbarCommands, Mode=OneWay}"
                                          CanDragItems="True"
                                          CanReorderItems="True"
                                          AllowDrop="True"
                                          SelectionMode="None"
                                          IsItemClickEnabled="True"
                                          Padding="0"
                                          Margin="0"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          HorizontalAlignment="Left"
                                          HorizontalContentAlignment="Left"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.HorizontalScrollMode="Enabled"
                                          ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                          ScrollViewer.VerticalScrollMode="Disabled"
                                          ItemClick="TopToolbarListView_ItemClick"
                                          DragItemsCompleted="ToolbarCommandsListView_DragItemsCompleted">
                                    <ListView.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <ItemsStackPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ListView.ItemsPanel>
                                    <ListView.ItemContainerStyle>
                                        <StaticResource ResourceKey="ToolbarListViewItemStyle" />
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:ToolbarCommandItem">
                                            <Border Padding="3,1"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="1"
                                                    CornerRadius="6"
                                                    PointerEntered="ToolbarItem_PointerEntered"
                                                    PointerExited="ToolbarItem_PointerExited">
                                                <Border.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="編輯"
                                                                        Tag="{x:Bind}"
                                                                        Click="EditToolbarCommand_Click" />
                                                        <MenuFlyoutItem Text="刪除"
                                                                        Tag="{x:Bind}"
                                                                        Click="DeleteToolbarCommand_Click" />
                                                    </MenuFlyout>
                                                </Border.ContextFlyout>
                                                <StackPanel MinWidth="38"
                                                            HorizontalAlignment="Center"
                                                            Spacing="0">
                                                    <Grid Width="32"
                                                          Height="30"
                                                          Tag="{x:Bind}"
                                                          Loaded="ToolbarIconPresenter_Loaded">
                                                        <Image Width="28"
                                                               Height="28"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Stretch="Uniform"
                                                               Visibility="Collapsed" />
                                                        <FontIcon Glyph="{x:Bind DisplayGlyph, Mode=OneWay}"
                                                                  FontSize="24"
                                                                  Foreground="{StaticResource TextPrimaryBrush}"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                    </Grid>
                                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="10"
                                                               HorizontalAlignment="Center"
                                                               TextAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               MaxWidth="62"
                                                               Margin="0,-1,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="LeftPaneBorder"
                                Grid.Column="0"
                                Padding="14"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Tapped="LeftPaneContainer_Tapped">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <TextBox x:Name="LeftPathTextBox"
                                         Text="{x:Bind LeftPane.EditablePath, Mode=TwoWay}"
                                         KeyDown="LeftPathBox_KeyDown"
                                         GotFocus="LeftPathTextBox_GotFocus"
                                         Background="{StaticResource InputBrush}"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         CornerRadius="12"
                                         Padding="12,10" />

                                <Grid Grid.Row="1"
                                      DataContext="{x:Bind LeftPane}"
                                      Margin="0,14,0,0"
                                      Visibility="{Binding FilterVisibility}">
                                    <Border Padding="12,10"
                                            Background="{StaticResource AccentSoftBrush}"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="12">
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding FilterModeText}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1"
                                                    Tag="{x:Bind LeftPane}"
                                                    Click="ClearPaneFilter_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Padding="8,4"
                                                    MinHeight="30"
                                                    Content="✕" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <ListView x:Name="LeftPaneListView"
                                          Grid.Row="2"
                                          Margin="0,14,0,0"
                                          ItemsSource="{x:Bind LeftPane.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource PaneListViewItemStyle}"
                                          IsItemClickEnabled="False"
                                          ContainerContentChanging="PaneListView_ContainerContentChanging"
                                          SelectionChanged="LeftPaneList_SelectionChanged"
                                          DoubleTapped="LeftPaneList_DoubleTapped"
                                          Tapped="LeftPaneList_Tapped"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          SelectionMode="Extended">
                                    <ListView.Header>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="名稱" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="1" Text="類型" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="2" Text="修改時間" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="3" Text="大小" Style="{StaticResource SectionTitleStyle}" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:FileEntry">
                                            <Border Padding="10"
                                                    Background="{x:Bind ItemBackground, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ItemBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ItemBorderThickness, Mode=OneWay}"
