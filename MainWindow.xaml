<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="nuone_tools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Nuone Tools">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout" Background="#141119">
        <Grid.Resources>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="#141119" />
            <SolidColorBrush x:Key="PanelBrush" Color="#211C28" />
            <SolidColorBrush x:Key="PanelAltBrush" Color="#191520" />
            <SolidColorBrush x:Key="PanelStrokeBrush" Color="#3A3146" />
            <SolidColorBrush x:Key="AccentBrush" Color="#BF4CFF" />
            <SolidColorBrush x:Key="AccentSoftBrush" Color="#8B35C4" />
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F6F2FF" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B9AECF" />
            <SolidColorBrush x:Key="SuccessBrush" Color="#74D89B" />
            <SolidColorBrush x:Key="WarningBrush" Color="#FFD76A" />

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CharacterSpacing" Value="60" />
                <Setter Property="TextWrapping" Value="NoWrap" />
            </Style>

            <Style x:Key="GhostButtonStyle" TargetType="Button">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="Background" Value="#00FFFFFF" />
                <Setter Property="BorderBrush" Value="{StaticResource PanelStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="MinHeight" Value="38" />
            </Style>

            <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            </Style>

            <Style x:Key="AppRailButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="CornerRadius" Value="14" />
            </Style>

            <Style x:Key="GroupCardListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>

            <Style x:Key="PaneListViewItemStyle" TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,0,2" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
        </Grid.Resources>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,0,0"
                Background="#0F2025"
                BorderBrush="#1F3138"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="10,14,10,0" Spacing="10">
                    <Button x:Name="FileManagerAppButton"
                            Click="ShowFileManagerApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="FileManagerAppButtonBorder"
                                Padding="10,12"
                                Background="#2D2835"
                                BorderBrush="#4A3E58"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="FileManagerAppIcon"
                                          Glyph="&#xE8B7;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="FileManagerAppText"
                                           Text="檔案"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <Button x:Name="SettingsAppButton"
                            Click="ShowSettingsApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="SettingsAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="SettingsAppIcon"
                                          Glyph="&#xE713;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="SettingsAppText"
                                           Text="設定"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="10,0,10,14"
                            Spacing="10">
                    <Border Padding="10,12"
                            Background="#171622"
                            BorderBrush="#2F2740"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="NT"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="工具"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid x:Name="FileManagerView" Visibility="Visible">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="14"
                        Padding="16"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource PanelStrokeBrush}"
                        BorderThickness="1"
                        CornerRadius="22">
                    <Grid RowDefinitions="Auto,*">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Nuone Tools"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="26"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="Nuone工具"
                                           Style="{StaticResource SectionTitleStyle}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Click="RefreshAll_Click"
                                    Style="{StaticResource GhostButtonStyle}">
                                <FontIcon Glyph="&#xE72C;" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1"
                                      Margin="0,20,0,0"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Spacing="18">
                                <Border Padding="10"
                                        Background="#2A252F"
                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="磁碟機" Style="{StaticResource SectionTitleStyle}" />
                                        <ItemsControl ItemsSource="{x:Bind Drives, Mode=OneWay}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="local:DriveShortcut">
                                                    <Button HorizontalAlignment="Stretch"
                                                            Padding="0"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Stretch"
                                                            Click="DriveShortcut_Click"
                                                            Tag="{x:Bind RootPath}">
                                                        <Border HorizontalAlignment="Stretch"
                                                                Margin="0,0,0,8"
                                                                Padding="12"
                                                                Background="#2A252F"
                                                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="10">
                                                            <StackPanel Spacing="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="{x:Bind Name}"
                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                               FontSize="14"
                                                                               FontWeight="SemiBold" />
                                                                    <TextBlock Grid.Column="1"
                                                                               Text="{x:Bind Summary}"
                                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                                </Grid>
                                                                <ProgressBar Value="{x:Bind UsagePercent}"
                                                                             Maximum="100"
                                                                             Height="6"
                                                                             Foreground="{StaticResource AccentBrush}"
                                                                             Background="#3A3146" />
                                                                <TextBlock Text="{x:Bind Detail}"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           FontSize="12" />
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <StackPanel Spacing="12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="自訂分組" Style="{StaticResource SectionTitleStyle}" />
                                        <Button Grid.Column="1"
                                                x:Name="AddGroupButton"
                                                Click="ShowAddGroupEditor_Click"
                                                Style="{StaticResource GhostButtonStyle}">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE710;" />
                                                <TextBlock Text="新增分組" />
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <StackPanel x:Name="AddGroupEditor"
                                                Visibility="Collapsed"
                                                Spacing="8">
                                        <TextBox x:Name="NewGroupNameTextBox"
                                                 PlaceholderText="輸入分組名稱"
                                                 Background="#1B1621"
                                                 BorderBrush="{StaticResource PanelStrokeBrush}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"
                                                 KeyDown="NewGroupNameTextBox_KeyDown" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Button Grid.Column="0"
                                                    Click="ConfirmAddGroup_Click"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Content="建立" />
                                            <Button Grid.Column="1"
                                                    Click="CancelAddGroup_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="取消" />
                                        </Grid>
                                    </StackPanel>

                                    <ListView x:Name="CustomGroupsListView"
                                              ItemsSource="{x:Bind CustomGroups, Mode=OneWay}"
                                              CanDragItems="True"
                                              CanReorderItems="True"
                                              AllowDrop="True"
                                              SelectionMode="None"
                                              IsItemClickEnabled="False"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              ItemContainerStyle="{StaticResource GroupCardListViewItemStyle}"
                                              DragItemsCompleted="CustomGroupsListView_DragItemsCompleted">
                                        <ListView.ItemTemplate>
                                            <DataTemplate x:DataType="local:PathGroup">
                                                <Border Margin="0,0,0,10"
                                                        Padding="10"
                                                        Background="#2A252F"
                                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="10">
                                                    <StackPanel Spacing="8">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{x:Bind Title}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold" />
                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                                                <Button Padding="0"
                                                                        Width="24"
                                                                        Height="24"
                                                                        MinHeight="24"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="6">
                                                                    <FontIcon Glyph="&#xE712;" />
                                                                    <Button.Flyout>
                                                                        <MenuFlyout>
                                                                            <MenuFlyoutItem Text="群組改名"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="RenameGroup_Click" />
                                                                            <MenuFlyoutItem Text="刪除分組"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="DeleteGroup_Click" />
                                                                            <MenuFlyoutSeparator />
                                                                            <MenuFlyoutItem Text="加入目前路徑"
                                                                                            Tag="{x:Bind}"
                                                                                            Click="AddCurrentPathToGroup_Click" />
                                                                        </MenuFlyout>
                                                                    </Button.Flyout>
                                                                </Button>
                                                                <Button Padding="0"
                                                                        Width="24"
                                                                        Height="24"
                                                                        MinHeight="24"
                                                                        Background="Transparent"
                                                                        BorderBrush="Transparent"
                                                                        BorderThickness="0"
                                                                        CornerRadius="6"
                                                                        Click="AddCurrentPathToGroup_Click">
                                                                    <FontIcon Glyph="&#xE710;" />
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>

                                                        <ItemsControl ItemsSource="{x:Bind Items}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="local:GroupedPathItem">
                                                                    <Button HorizontalAlignment="Stretch"
                                                                            Padding="0"
                                                                            Background="Transparent"
                                                                            BorderThickness="0"
                                                                            HorizontalContentAlignment="Stretch"
                                                                            Click="GroupedPath_Click"
                                                                            Tag="{x:Bind Path}">
                                                                        <Border HorizontalAlignment="Stretch"
                                                                                Margin="0,0,0,2"
                                                                                Padding="8,5"
                                                                                Background="Transparent"
                                                                                BorderBrush="Transparent"
                                                                                BorderThickness="0"
                                                                                CornerRadius="6">
                                                                            <Border.ContextFlyout>
                                                                                <MenuFlyout>
                                                                                    <MenuFlyoutItem Text="開啟"
                                                                                                    Tag="{x:Bind}"
                                                                                                    Click="GroupedPathOpen_Click" />
                                                                                    <MenuFlyoutItem Text="更改別名"
                                                                                                    Tag="{x:Bind}"
                                                                                                    Click="RenameGroupedPathAlias_Click" />
                                                                                    <MenuFlyoutItem Text="從分組移除"
                                                                                                    Tag="{x:Bind}"
                                                                                                    Click="RemoveGroupedPath_Click" />
                                                                                </MenuFlyout>
                                                                            </Border.ContextFlyout>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <FontIcon Glyph="&#xE8B7;"
                                                                                          Foreground="{StaticResource WarningBrush}"
                                                                                          Margin="0,0,8,0"
                                                                                          FontSize="13" />
                                                                                <StackPanel Grid.Column="1" Spacing="2">
                                                                                    <TextBlock Text="{x:Bind Title}"
                                                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                                                               FontSize="13" />
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </Border>
                                                                    </Button>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="0,14,14,14" RowDefinitions="Auto,*">
                    <Border x:Name="TopCommandBarBorder"
                            Padding="16"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="22">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Style="{StaticResource GhostButtonStyle}" Click="BackLeft_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72B;" />
                                        <TextBlock Text="左側返回" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Click="BackRight_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72B;" />
                                        <TextBlock Text="右側返回" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Click="SwapPanes_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8AB;" />
                                        <TextBlock Text="交換 Pane" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                <Button Style="{StaticResource AccentButtonStyle}" Click="OpenSelected_Click">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE8A7;" />
                                        <TextBlock Text="開啟選取" />
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource GhostButtonStyle}" Click="RefreshAll_Click">
                                    <FontIcon Glyph="&#xE72C;" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="LeftPaneBorder"
                                Grid.Column="0"
                                Padding="14"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Tapped="LeftPaneContainer_Tapped">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <TextBox x:Name="LeftPathTextBox"
                                         Text="{x:Bind LeftPane.EditablePath, Mode=TwoWay}"
                                         KeyDown="LeftPathBox_KeyDown"
                                         GotFocus="LeftPathTextBox_GotFocus"
                                         Background="#1B1621"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         CornerRadius="12"
                                         Padding="12,10" />

                                <Border x:Name="LeftPaneStatusBorder"
                                        Grid.Row="1"
                                        Margin="0,14,0,14"
                                        Padding="12"
                                        Background="#1B1621"
                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind LeftPane.StatusText, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind LeftPane.SummaryText, Mode=OneWay}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   Margin="10,0,0,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind LeftPane.SelectionText, Mode=OneWay}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                </Border>

                                <ListView x:Name="LeftPaneListView"
                                          Grid.Row="2"
                                          ItemsSource="{x:Bind LeftPane.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource PaneListViewItemStyle}"
                                          IsItemClickEnabled="False"
                                          ContainerContentChanging="PaneListView_ContainerContentChanging"
                                          SelectionChanged="LeftPaneList_SelectionChanged"
                                          DoubleTapped="LeftPaneList_DoubleTapped"
                                          Tapped="LeftPaneList_Tapped"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          SelectionMode="Extended">
                                    <ListView.Header>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="名稱" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="1" Text="類型" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="2" Text="修改時間" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="3" Text="大小" Style="{StaticResource SectionTitleStyle}" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:FileEntry">
                                            <Border Padding="10"
                                                    Background="{x:Bind ItemBackground, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ItemBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ItemBorderThickness, Mode=OneWay}"
                                                    CornerRadius="12"
                                                    Tapped="LeftPaneEntry_Tapped"
                                                    RightTapped="LeftPaneEntry_RightTapped">
                                                <Border.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="開啟"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="OpenPath_Click" />
                                                        <MenuFlyoutItem Text="在另一側打開"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="OpenInRightPane_Click" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="複製到另一側"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CopyToRightPane_Click" />
                                                        <MenuFlyoutItem Text="搬移到另一側"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="MoveToRightPane_Click" />
                                                        <MenuFlyoutItem Text="重新命名"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="RenamePath_Click" />
                                                        <MenuFlyoutItem Text="刪除"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="DeletePath_Click" />
                                                        <MenuFlyoutItem Text="新增資料夾"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CreateFolderLeft_Click" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="複製路徑"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CopyPath_Click" />
                                                    </MenuFlyout>
                                                </Border.ContextFlyout>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                                  Foreground="{x:Bind AccentColor}" />
                                                        <TextBlock Text="{x:Bind Name}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind Kind}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind ModifiedText}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{x:Bind SizeText}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border x:Name="RightPaneBorder"
                                Grid.Column="2"
                                Padding="14"
                                Background="{StaticResource PanelBrush}"
                                BorderBrush="{StaticResource PanelStrokeBrush}"
                                BorderThickness="1"
                                CornerRadius="22"
                                Tapped="RightPaneContainer_Tapped">
                            <Grid RowDefinitions="Auto,Auto,*">
                                <TextBox x:Name="RightPathTextBox"
                                         Text="{x:Bind RightPane.EditablePath, Mode=TwoWay}"
                                         KeyDown="RightPathBox_KeyDown"
                                         GotFocus="RightPathTextBox_GotFocus"
                                         Background="#1B1621"
                                         BorderBrush="{StaticResource PanelStrokeBrush}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontSize="16"
                                         FontWeight="SemiBold"
                                         CornerRadius="12"
                                         Padding="12,10" />

                                <Border x:Name="RightPaneStatusBorder"
                                        Grid.Row="1"
                                        Margin="0,14,0,14"
                                        Padding="12"
                                        Background="#1B1621"
                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind RightPane.StatusText, Mode=OneWay}"
                                                   Foreground="{StaticResource TextSecondaryBrush}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{x:Bind RightPane.SummaryText, Mode=OneWay}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   Margin="10,0,0,0" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{x:Bind RightPane.SelectionText, Mode=OneWay}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                </Border>

                                <ListView x:Name="RightPaneListView"
                                          Grid.Row="2"
                                          ItemsSource="{x:Bind RightPane.Items, Mode=OneWay}"
                                          ItemContainerStyle="{StaticResource PaneListViewItemStyle}"
                                          IsItemClickEnabled="False"
                                          ContainerContentChanging="PaneListView_ContainerContentChanging"
                                          SelectionChanged="RightPaneList_SelectionChanged"
                                          DoubleTapped="RightPaneList_DoubleTapped"
                                          Tapped="RightPaneList_Tapped"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          SelectionMode="Extended">
                                    <ListView.Header>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="110" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="名稱" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="1" Text="類型" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="2" Text="修改時間" Style="{StaticResource SectionTitleStyle}" />
                                            <TextBlock Grid.Column="3" Text="大小" Style="{StaticResource SectionTitleStyle}" />
                                        </Grid>
                                    </ListView.Header>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:FileEntry">
                                            <Border Padding="10"
                                                    Background="{x:Bind ItemBackground, Mode=OneWay}"
                                                    BorderBrush="{x:Bind ItemBorderBrush, Mode=OneWay}"
                                                    BorderThickness="{x:Bind ItemBorderThickness, Mode=OneWay}"
                                                    CornerRadius="12"
                                                    Tapped="RightPaneEntry_Tapped"
                                                    RightTapped="RightPaneEntry_RightTapped">
                                                <Border.ContextFlyout>
                                                    <MenuFlyout>
                                                        <MenuFlyoutItem Text="開啟"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="OpenPath_Click" />
                                                        <MenuFlyoutItem Text="在另一側打開"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="OpenInLeftPane_Click" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="複製到另一側"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CopyToLeftPane_Click" />
                                                        <MenuFlyoutItem Text="搬移到另一側"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="MoveToLeftPane_Click" />
                                                        <MenuFlyoutItem Text="重新命名"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="RenamePath_Click" />
                                                        <MenuFlyoutItem Text="刪除"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="DeletePath_Click" />
                                                        <MenuFlyoutItem Text="新增資料夾"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CreateFolderRight_Click" />
                                                        <MenuFlyoutSeparator />
                                                        <MenuFlyoutItem Text="複製路徑"
                                                                        Tag="{Binding FullPath}"
                                                                        Click="CopyPath_Click" />
                                                    </MenuFlyout>
                                                </Border.ContextFlyout>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="150" />
                                                        <ColumnDefinition Width="120" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                                        <FontIcon Glyph="{x:Bind Glyph}"
                                                                  Foreground="{x:Bind AccentColor}" />
                                                        <TextBlock Text="{x:Bind Name}"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{x:Bind Kind}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="2"
                                                               Text="{x:Bind ModifiedText}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                    <TextBlock Grid.Column="3"
                                                               Text="{x:Bind SizeText}"
                                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <Grid x:Name="SettingsView" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="18"
                            Padding="20"
                            Background="{StaticResource PanelAltBrush}"
                            BorderBrush="{StaticResource PanelStrokeBrush}"
                            BorderThickness="1"
                            CornerRadius="18">
                        <StackPanel Spacing="18">
                            <TextBlock Text="設定"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="28"
                                       FontWeight="SemiBold" />

                            <TextBox PlaceholderText="在設定中尋找"
                                     IsReadOnly="True"
                                     Background="#231E2B"
                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                     Foreground="{StaticResource TextPrimaryBrush}" />

                            <Button Click="ShowGeneralSettings_Click"
                                    Style="{StaticResource AppRailButtonStyle}">
                                <Border x:Name="GeneralSettingsNavBorder"
                                        Padding="14,12"
                                        Background="#2A252F"
                                        BorderBrush="{StaticResource PanelStrokeBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock x:Name="GeneralSettingsNavText"
                                               Text="一般"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="16"
                                               FontWeight="SemiBold" />
                                </Border>
                            </Button>

                            <Button Click="ShowAppearanceSettings_Click"
                                    Style="{StaticResource AppRailButtonStyle}">
                                <Border x:Name="AppearanceSettingsNavBorder"
                                        Padding="14,12"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock x:Name="AppearanceSettingsNavText"
                                               Text="外觀"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="16" />
                                </Border>
                            </Button>

                            <Button Click="ShowShortcutSettings_Click"
                                    Style="{StaticResource AppRailButtonStyle}">
                                <Border x:Name="ShortcutSettingsNavBorder"
                                        Padding="14,12"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <TextBlock x:Name="ShortcutSettingsNavText"
                                               Text="快捷鍵"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="16" />
                                </Border>
                            </Button>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1"
                                  Margin="0,18,18,18"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="18">
                            <TextBlock x:Name="SettingsPageTitle"
                                       Text="一般"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="34"
                                       FontWeight="SemiBold" />

                            <TextBlock x:Name="SettingsPageDescription"
                                       Text="設定檔案管理和常用鍵盤快捷鍵。變更後會儲存到本機 config。"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="16"
                                       TextWrapping="Wrap" />

                            <Border x:Name="GeneralSettingsContent"
                                    Padding="24"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Visibility="Visible">
                                <StackPanel Spacing="18">
                                    <TextBlock Text="檔案顯示"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold" />

                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Spacing="6">
                                            <TextBlock Text="顯示隱藏與系統檔案"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="包含 Hidden、System、ReparsePoint 項目。"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <ToggleSwitch x:Name="ShowHiddenSystemItemsToggle"
                                                      Grid.Column="1"
                                                      VerticalAlignment="Center"
                                                      OffContent="關"
                                                      OnContent="開" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="AppearanceSettingsContent"
                                    Padding="24"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Visibility="Collapsed">
                                <StackPanel Spacing="18">
                                    <TextBlock Text="外觀"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="外觀設定稍後會放在這裡。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="ShortcutSettingsContent"
                                    Padding="24"
                                    Background="{StaticResource PanelBrush}"
                                    BorderBrush="{StaticResource PanelStrokeBrush}"
                                    BorderThickness="1"
                                    CornerRadius="18"
                                    Visibility="Collapsed">
                                <StackPanel Spacing="18">
                                    <TextBlock Text="快捷鍵"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               FontSize="24"
                                               FontWeight="SemiBold" />

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="複製到另一個 Pane"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="目前作用中的 pane 按下後，複製選取項目到另一側。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="CopyShortcutTextBox"
                                                     IsReadOnly="True"
                                                     Background="#231E2B"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Button Grid.Column="1"
                                                    Click="EditCopyShortcut_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="修改" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="移動到另一個 Pane"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="目前作用中的 pane 按下後，將選取項目搬移到另一側。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="MoveShortcutTextBox"
                                                     IsReadOnly="True"
                                                     Background="#231E2B"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Button Grid.Column="1"
                                                    Click="EditMoveShortcut_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="修改" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="上一層"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="目前作用中的 pane 按下後，回到上一層目錄。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="NavigateUpShortcutTextBox"
                                                     IsReadOnly="True"
                                                     Background="#231E2B"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Button Grid.Column="1"
                                                    Click="EditNavigateUpShortcut_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="修改" />
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Spacing="8">
                                        <TextBlock Text="刪除"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="目前作用中的 pane 按下後，刪除選取項目。"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="15"
                                                   TextWrapping="Wrap" />
                                        <Grid ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="DeleteShortcutTextBox"
                                                     IsReadOnly="True"
                                                     Background="#231E2B"
                                                     BorderBrush="{StaticResource PanelStrokeBrush}"
                                                     Foreground="{StaticResource TextPrimaryBrush}" />
                                            <Button Grid.Column="1"
                                                    Click="EditDeleteShortcut_Click"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Content="修改" />
                                        </Grid>
                                    </StackPanel>

                                    <TextBlock x:Name="CaptureHintTextBlock"
                                               Text="按「修改」後，再按下實體鍵。"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               FontSize="15"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Row="1"
                      Margin="18,0,18,18"
                      ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="220" />
                        <ColumnDefinition Width="220" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1"
                            Click="SaveSettingsPage_Click"
                            Style="{StaticResource AccentButtonStyle}"
                            Content="儲存" />
                    <Button Grid.Column="2"
                            Click="CancelSettingsPage_Click"
                            Style="{StaticResource GhostButtonStyle}"
                            Content="取消" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
