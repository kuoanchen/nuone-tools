<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="nuone_tools.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:nuone_tools"
    xmlns:views="using:nuone_tools.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Nuone Tools">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootLayout"
          Background="#141119"
          ActualThemeChanged="RootLayout_ActualThemeChanged">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="84" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="0,0,0,0"
                Background="{StaticResource AppRailBrush}"
                BorderBrush="{StaticResource AppRailBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,*,Auto">
                <StackPanel Margin="10,14,10,0" Spacing="10">
                    <Button x:Name="FileManagerAppButton"
                            Click="ShowFileManagerApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="FileManagerAppButtonBorder"
                                Padding="10,12"
                                Background="{StaticResource AppRailActiveBrush}"
                                BorderBrush="{StaticResource AppRailActiveBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="FileManagerAppIcon"
                                          Glyph="&#xE8B7;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextPrimaryBrush}" />
                                <TextBlock x:Name="FileManagerAppText"
                                           Text="檔案"
                                           FontSize="11"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>

                    <Button x:Name="AutomationAppButton"
                            Click="ShowAutomationApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="AutomationAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="AutomationAppIcon"
                                          Glyph="&#xE7B8;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="AutomationAppText"
                                           Text="自動化"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>
                    
                    <Button x:Name="TerminalAppButton"
                            Click="ShowTerminalApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="TerminalAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="TerminalAppIcon"
                                          Glyph="&#xE756;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="TerminalAppText"
                                           Text="終端機"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>
                    
                    <Button x:Name="SettingsAppButton"
                            Click="ShowSettingsApp_Click"
                            Style="{StaticResource AppRailButtonStyle}">
                        <Border x:Name="SettingsAppButtonBorder"
                                Padding="10,12"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="14">
                            <StackPanel HorizontalAlignment="Center" Spacing="6">
                                <FontIcon x:Name="SettingsAppIcon"
                                          Glyph="&#xE713;"
                                          FontSize="18"
                                          Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock x:Name="SettingsAppText"
                                           Text="設定"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Button>

                </StackPanel>

                <StackPanel Grid.Row="2"
                            Margin="10,0,10,14"
                            Spacing="10">
                    <Border Padding="10,12"
                            Background="{StaticResource AppRailFooterBrush}"
                            BorderBrush="{StaticResource AppRailFooterBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel HorizontalAlignment="Center" Spacing="2">
                            <TextBlock Text="{x:Bind AppVersionText, Mode=OneWay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                            <TextBlock Text="版本"
                                       FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="TopTitleBar"
                    Grid.Row="0"
                    Background="{StaticResource AppRailFooterBrush}"
                    BorderBrush="{StaticResource AppRailFooterBorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid Padding="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button x:Name="BackgroundWorkNotificationButton"
                            Click="BackgroundWorkNotification_Click"
                            Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Padding="8,3"
                            Background="Transparent"
                            BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE9F5;"
                                      FontSize="13"
                                      Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock x:Name="BackgroundWorkTopStatusText"
                                       Text="目前沒有執行中的工作"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                            <Border x:Name="BackgroundWorkHistoryCountBadge"
                                    Padding="6,1"
                                    Background="{StaticResource AppRailActiveBrush}"
                                    BorderBrush="{StaticResource AppRailActiveBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="999"
                                    Visibility="Collapsed">
                                <TextBlock x:Name="BackgroundWorkHistoryCountText"
                                           Text="0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="11"
                                           FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                    </Button>

                    <Grid Grid.Column="0"
                          Background="Transparent" />

                    <Grid Grid.Column="2"
                          Background="Transparent" />
                </Grid>
            </Border>

            <views:FileManagerView x:Name="FileManagerPage"
                                   Grid.Row="1"
                                   Visibility="Visible" />

            <views:AutomationView x:Name="AutomationPage"
                                  Grid.Row="1"
                                  Visibility="Collapsed" />

            <views:SettingsView x:Name="SettingsPage"
                                Grid.Row="1"
                                Visibility="Collapsed" />

            <views:TerminalView x:Name="TerminalPage"
                                Grid.Row="1"
                                Visibility="Collapsed" />

            <Border Grid.Row="2"
                    Background="{StaticResource AppRailFooterBrush}"
                    BorderBrush="{StaticResource AppRailFooterBorderBrush}"
                    BorderThickness="1,1,0,0">
                <Grid Padding="14,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.4*" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="0.9*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="10,4"
                            Background="{StaticResource AppRailActiveBrush}"
                            BorderBrush="{StaticResource AppRailActiveBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="999">
                        <TextBlock x:Name="SharedStatusSectionText"
                                   Text="檔案管理"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="12"
                                   FontWeight="SemiBold" />
                    </Border>

                    <TextBlock x:Name="SharedStatusPrimaryText"
                               Grid.Column="2"
                               Text="準備就緒"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />

                    <TextBlock x:Name="SharedStatusDetailText"
                               Grid.Column="4"
                               Text="Nuone Tools"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
